{
  "name": "pilot-ai",
  "version": "0.5.23",
  "description": "Personal AI agent that controls your macOS via Slack or Telegram",
  "type": "module",
  "bin": {
    "pilot-ai": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "agent",
    "automation",
    "macos",
    "slack",
    "telegram"
  ],
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@anthropic-ai/sdk": "^0.78.0",
    "@notionhq/client": "^5.11.1",
    "@slack/bolt": "^4.6.0",
    "@types/inquirer": "^9.0.9",
    "commander": "^14.0.3",
    "inquirer": "^13.3.0",
    "playwright": "^1.58.2",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.5",
    "eslint": "^9.39.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  }
}
